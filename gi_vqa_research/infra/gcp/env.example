# Non-secret identifiers and paths only. Do not add API keys or access tokens.

GCP_PROJECT_ID=your-project-id
GCP_ZONE=your-zone
GCP_VM_NAME=your-vm-name

# One prefix per study. run_job.sh appends RUN_ID.
GCS_RUN_ROOT=gs://your-bucket/runs/study1

# Disposable VM-local cache and run staging area.
GI_VQA_WORK_ROOT=/home/your-user/gi-vqa-work

# Normally auto-detected as <git-root>/gi_vqa_research.
# PROJECT_ROOT=/home/your-user/path/to/repository/gi_vqa_research

# Set independently for every run.
RUN_ID=study1-condition-gitsha-seed-utc

# Optional bootstrap controls.
# INSTALL_DEPS=0
# DEPENDENCY_LOCK_FILE=requirements.lock

# Safety overrides are intentionally disabled.
# ALLOW_DIRTY=0
# AUTO_SHUTDOWN=0
