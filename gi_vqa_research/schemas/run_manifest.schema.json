{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/gi-vqa/run-manifest.schema.json",
  "title": "GI-VQA run manifest",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "stage",
    "created_at_utc",
    "config",
    "config_sha256",
    "inputs",
    "runtime",
    "manifest_content_sha256"
  ],
  "properties": {
    "schema_version": { "const": "gi-vqa-run-manifest-v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "stage": { "type": "string", "minLength": 1 },
    "created_at_utc": { "type": "string", "format": "date-time" },
    "code_revision": { "type": ["string", "null"] },
    "command": { "type": "array", "items": { "type": "string" } },
    "config": {
      "type": "object"
    },
    "config_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "inputs": { "type": "object" },
    "runtime": { "type": "object" },
    "manifest_content_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "additionalProperties": true
}
